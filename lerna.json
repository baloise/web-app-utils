{
  "version": "3.17.0",
  "granularPathspec": false,
  "packages": ["packages/*"],
  "useWorkspaces": true,
  "npmClient": "npm",
  "command": {
    "version": {
      "message": "chore(release): publish %s"
    }
  },
  "ignoreChanges": [
    ".build/**",
    ".github/**",
    ".husky/**",
    "**/.build/**",
    "**/generated/**",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e.ts",
    "**/*.md"
  ],
  "$schema": "node_modules/lerna/schemas/lerna-schema.json"
}
